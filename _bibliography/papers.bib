  pdf          = {https://openaccess.thecvf.com/content/ICCV2025W/R6D/papers/Gouda_MR6D_Benchmarking_6D_Pose_Estimation_for_Mobile_Robots_ICCVW_2025_paper.pdf},
  selected     = {true},
  abbr         = {ICCV},

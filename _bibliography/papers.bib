@InProceedings{Gouda_2025_ICCV,
  author       = {Gouda, Anas and Awasthi, Shrutarv and Blesing, Christian and
                  Manohar, Lokeshwaran and Hoffmann, Frank and Kirchheim, Alice},
  title        = {MR6D: Benchmarking 6D Pose Estimation for Mobile Robots},
  booktitle    = {Proceedings of the IEEE/CVF International Conference on
                  Computer Vision (ICCV) Workshops},
  month        = {October},
  year         = {2025},
  pages        = {2447--2455},
